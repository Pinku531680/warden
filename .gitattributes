# 1. Mark the entire UI folder as documentation
# This keeps the files visible but removes them from the stats bar
warden-ui/** linguist-documentation

# 2. Alternatively, if you want SOME JS to show, only detect the main App logic
# This tells Git: "Ignore everything in UI, EXCEPT these specific files"
warden-ui/** linguist-detectable=false
warden-ui/src/App.js linguist-detectable=true
warden-ui/src/users/** linguist-detectable=true

# 3. Keep your ML and Backend as the primary focus
warden-ml/** linguist-detectable=true
warden-backend/** linguist-detectable=true

# 4. If you have any large CSS files that are skewing stats
warden-ui/src/*.css linguist-vendored