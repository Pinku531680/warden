# -----------------------------------------------------------------------------
# GitHub Linguist Overrides - Language Statistics Cleanup
# -----------------------------------------------------------------------------

# Treat compiled/generated Protobuf files as generated (removes from stats & hides from diffs)
warden-ui/src/proto/compiled.js linguist-generated=true
warden-ui/src/proto/compiled.d.ts linguist-generated=true

# Exclude synthetic data generation scripts from the language statistics bar
warden-ui/src/transactions/TransactionsDataGeneration.js linguist-generated=true
warden-ui/src/users/UsersDataGeneration.js linguist-generated=true

# Optional: Catch-all rule for any other data generation files you add later
*DataGeneration.js linguist-generated=true




