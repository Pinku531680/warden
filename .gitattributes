# 1. Neutralize the heavy assets and boilerplate
warden-ui/public/** linguist-vendored
warden-ui/src/reportWebVitals.js linguist-vendored
warden-ui/src/setupTests.js linguist-vendored
warden-ui/src/*.css linguist-vendored

# 2. Specifically target the "Data Generation" bloat
# We mark these as 'generated' so they are hidden from stats but still searchable
warden-ui/src/users/UsersDataGeneration.js linguist-generated
warden-ui/src/transactions/TransactionsDataGeneration.js linguist-generated
warden-ui/src/utilities.js linguist-generated

# 3. Kill the XML noise
# This prevents pom.xml or IDE files from stealing the spotlight
*.xml linguist-vendored
.idea/** linguist-vendored

# 4. Ensure your "Logic" JS is still counted
warden-ui/src/users/UsersFeatureAnalytics.js linguist-detectable=true
warden-ui/src/transactions/** linguist-detectable=true
warden-ui/src/*.css linguist-detectable=true